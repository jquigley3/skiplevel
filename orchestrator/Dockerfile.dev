# macro-claw dev/test image
# Installs all dependencies (including devDependencies) and mounts source at runtime.
# Never used in production — only for local development and CI.
#
# Build:  docker build -t macro-claw-dev:latest -f orchestrator/Dockerfile.dev orchestrator
# Test:   docker run --rm -v "$(pwd)/orchestrator:/app" macro-claw-dev:latest npm test
# Check:  docker run --rm -v "$(pwd)/orchestrator:/app" macro-claw-dev:latest npm run typecheck

FROM node:22-slim

RUN apt-get update && apt-get install -y \
    git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy manifests first so this layer is cached across source changes
COPY package*.json ./

# Install all deps (including devDependencies) inside the image
RUN npm install

# Source is volume-mounted at runtime — nothing to COPY here.
# This keeps the image reusable across edits without rebuilding.

CMD ["npm", "test"]
