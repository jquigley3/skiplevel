# macro-claw — environment configuration
# Copy this file to .env and fill in the values below.
#
# Quick start (minimum required):
#   HOST_PROJECTS_DIR=/absolute/path/to/your/projects
#   ANTHROPIC_API_KEY=sk-ant-...   # or use CLAUDE_CODE_OAUTH_TOKEN
#   (then: docker compose up -d)

# ── Required ────────────────────────────────────────────────────────────────

# Absolute path on the host to the directory containing your managed projects.
# Each subdirectory is one project: <HOST_PROJECTS_DIR>/<project>/tasks/*.yaml
# For a self-contained setup, point this at the projects/ dir in this repo:
#   HOST_PROJECTS_DIR=/path/to/macro-claw/projects
HOST_PROJECTS_DIR=

# ── Credentials (one of the two below is required) ──────────────────────────

# Option A — Anthropic API key (recommended for CI / headless use)
# ANTHROPIC_API_KEY=sk-ant-...

# Option B — Claude Code OAuth token (for personal/interactive use)
# Refresh from macOS Keychain with: ./dev.sh token
# CLAUDE_CODE_OAUTH_TOKEN=

# ── Optional ────────────────────────────────────────────────────────────────

# Path to a read-only shared reference directory mounted into sub-agents.
# Leave unset if you don't have a PKB / shared resource directory.
# HOST_PKB_DIR=

# ── Advanced ────────────────────────────────────────────────────────────────

# Docker image used for sub-agent containers. Build with: ./start.sh
# CONTAINER_IMAGE=agent-harness:latest

# Log verbosity: trace | debug | info | warn | error
# LOG_LEVEL=info
